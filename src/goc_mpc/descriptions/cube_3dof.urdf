<?xml version="1.0"?>
<robot name="cube_3dof">
  <link name="cb_px">
    <inertial><mass value="1e-6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" iyy="1e-9" izz="1e-9" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <link name="cb_py">
    <inertial><mass value="1e-6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" iyy="1e-9" izz="1e-9" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <link name="cb_body">
    <inertial><mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="5e-4" iyy="5e-4" izz="5e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="blue"><color rgba="0.1 0.2 0.8 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
    </collision>
  </link>

  <joint name="jx" type="prismatic">
    <parent link="world"/>
    <child  link="cb_px"/>
    <origin xyz="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-10" upper="10" effort="1000" velocity="5"/>
  </joint>
  <joint name="jy" type="prismatic">
    <parent link="cb_px"/>
    <child  link="cb_py"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-10" upper="10" effort="1000" velocity="5"/>
  </joint>
  <joint name="jz" type="prismatic">
    <parent link="cb_py"/>
    <child  link="cb_body"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-10" upper="10" effort="1000" velocity="5"/>
  </joint>
</robot>
