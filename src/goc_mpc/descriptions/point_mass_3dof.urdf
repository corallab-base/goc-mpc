<?xml version="1.0"?>
<robot name="point_mass_3dof">
  <!-- tiny mass/inertia for intermediate "massless" links -->
  <link name="pm_px">
    <inertial><mass value="1e-6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" iyy="1e-9" izz="1e-9" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <link name="pm_py">
    <inertial><mass value="1e-6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-9" iyy="1e-9" izz="1e-9" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- The actual point mass (visualized as a small sphere) -->
  <link name="pm_body">
    <inertial><mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.02"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
  </link>

  <!-- 3 translational DOFs: x, then y, then z -->
  <joint name="jx" type="prismatic">
    <parent link="world"/>
    <child  link="pm_px"/>
    <origin xyz="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-10" upper="10" effort="1000" velocity="5"/>
  </joint>
  <joint name="jy" type="prismatic">
    <parent link="pm_px"/>
    <child  link="pm_py"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-10" upper="10" effort="1000" velocity="5"/>
  </joint>
  <joint name="jz" type="prismatic">
    <parent link="pm_py"/>
    <child  link="pm_body"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-10" upper="10" effort="1000" velocity="5"/>
  </joint>
</robot>